# Copy this file to .env and fill in your values.
# These environment variables are used by docker-compose.

# ── Holodex API ────────────────────────────────────────────────────────────────
HOLODEX_TOKEN=your_holodex_api_token_here

# ── Database (only needed when NOT using the bundled docker-compose db service)
# DATABASE_URL=postgresql://user:password@host:5432/vtchive

# ── Application ────────────────────────────────────────────────────────────────
# TIMEZONE=Asia/Taipei
# MONITOR_INTERVAL=300
# MAX_CONCURRENT_DOWNLOADS=3
